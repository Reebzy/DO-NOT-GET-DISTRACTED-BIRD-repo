{
  "manifest_version": 3,
  "name": "DONT GET DISTRACTED BIRD",
  "version": "1.0.0",
  "description": "A stern heraldic cardinal that guards your focus tabs. Friction, not blockade — you can always leave, but only deliberately.",

  "permissions": [
    "tabs",
    "windows",
    "notifications",
    "storage",
    "scripting",
    "activeTab",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "assets/icon-16.png",
      "32":  "assets/icon-32.png",
      "48":  "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },

  "icons": {
    "16":  "assets/icon-16.png",
    "32":  "assets/icon-32.png",
    "48":  "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "interstitial/interstitial.html",
        "assets/*.svg",
        "assets/*.png",
        "shared/design-system.css"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
