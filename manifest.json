{
  "manifest_version": 3,
  "name": "DONT GET DISTRACTED BIRD",
  "version": "1.0.0",
  "description": "THE BIRD WILL NOT LET YOU GET DISTRACTED. Locks down your browser to only let you work on what you want to, and helps you avoid accidentally finding yourself two hundred youtube shorts deep an hour later with no work done by adding barriers to prevent accidentally leaving what you are meant to. The bird brings you back where you need to be, not where you want to go.",

  "permissions": [
    "tabs",
    "windows",
    "storage",
    "scripting",
    "activeTab",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "assets/icon-16.png",
      "32":  "assets/icon-32.png",
      "48":  "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },

  "icons": {
    "16":  "assets/icon-16.png",
    "32":  "assets/icon-32.png",
    "48":  "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },

  "commands": {
    "toggle-focus-hotkey": {
      "suggested_key": { "default": "Ctrl+Shift+F" },
      "description": "Start/end focus mode"
    },
    "toggle-pause-hotkey": {
      "suggested_key": { "default": "Ctrl+Shift+Space" },
      "description": "Pause/resume focus mode"
    }
  },

  "web_accessible_resources": [
    {
      "resources": [
        "interstitial/interstitial.html",
        "assets/*.svg",
        "assets/*.png",
        "shared/design-system.css"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
